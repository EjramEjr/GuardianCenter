<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/collapsed_view"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/ic_launcher_background"
        android:src="@android:drawable/ic_menu_compass"
        android:backgroundTint="#00d4ff"
        android:elevation="10dp"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/expanded_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#E60F1419"
        android:orientation="vertical"
        android:padding="15dp"
        android:layout_margin="10dp"
        android:elevation="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ Gamer VIP"
                android:textColor="#00d4ff"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_close_overlay"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="#ff4757"
                android:text="X"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#30363d" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>

        <LinearLayout android:layout_width="200dp" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="FPS" android:textColor="#8b949e" android:textSize="10sp"/>
                <TextView android:id="@+id/txt_fps" android:text="60" android:textColor="#2ed573" android:textSize="18sp" android:textStyle="bold"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="RAM" android:textColor="#8b949e" android:textSize="10sp"/>
                <TextView android:id="@+id/txt_ram" android:text="75%" android:textColor="#ffa502" android:textSize="18sp" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="15dp" android:gravity="center">
            <Button android:id="@+id/btn_clean_ram" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="#0099cc" android:text="تنظيف" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginEnd="5dp" />
            <Button android:id="@+id/btn_dnd" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="#30363d" android:text="عدم الإزعاج" android:textColor="#e6edf3" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
